<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Bill of Service - <%= fee.receiptNo %>
    </title>
    <!-- Bootstrap CSS -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.0/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <!-- Google Fonts for Serif Look -->
    <link
        href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=Roboto:wght@400;500;700&display=swap"
        rel="stylesheet">
    <style>
        body {
            background-color: #f8f9fa;
            font-family: 'Roboto', sans-serif;
            color: #333;
        }

        .receipt-container {
            max-width: 800px;
            margin: 40px auto;
            background: #fff;
            padding: 40px;
            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
            border: 1px solid #ccc;
        }

        /* Top Header Styling */
        .institute-header {
            text-align: center;
            margin-bottom: 20px;
        }

        .institute-name {
            font-family: 'Playfair Display', serif;
            font-size: 28px;
            font-weight: 700;
            letter-spacing: 1px;
            margin-bottom: 5px;
            color: #000;
        }

        .sub-name {
            font-family: 'Playfair Display', serif;
            font-size: 16px;
            color: #555;
            margin-bottom: 15px;
        }

        .institute-address {
            font-size: 14px;
            font-weight: 600;
            padding-bottom: 15px;
            border-bottom: 2px solid #000;
        }

        /* Middle Header Styling */
        .bill-header {
            display: flex;
            justify-content: center;
            align-items: center;
            margin-top: 15px;
            margin-bottom: 25px;
            position: relative;
        }

        .bill-box {
            border: 1px solid #000;
            padding: 8px 25px;
            font-weight: bold;
            font-size: 1.1rem;
            color: #000;
        }

        /* Information Section */
        .info-row {
            display: flex;
            justify-content: space-between;
            margin-bottom: 12px;
            font-weight: 600;
            font-size: 14px;
            color: #000;
        }

        .info-group {
            margin-bottom: 10px;
            font-weight: 600;
            font-size: 14px;
            color: #000;
            text-transform: uppercase;
        }

        /* Table Styling */
        .amount-table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 20px;
            margin-bottom: 30px;
        }

        .amount-table th,
        .amount-table td {
            border: 1px solid #000;
            padding: 10px 15px;
            font-size: 13px;
            color: #000;
        }

        .amount-table th {
            text-align: center;
            font-weight: 700;
            background-color: transparent !important;
        }

        .description-col {
            width: 70%;
        }

        .amount-col {
            width: 30%;
            text-align: right;
            font-weight: 700;
        }

        .in-words-row td {
            font-weight: 600;
            border-top: 2px solid #000;
            /* Thicker border for total */
        }

        .in-words-label {
            float: left;
        }

        .in-words-text {
            float: right;
            text-transform: uppercase;
        }

        /* Signature Section */
        .signature-section {
            display: flex;
            justify-content: space-between;
            margin-top: 60px;
            margin-bottom: 20px;
        }

        .signature-box {
            width: 200px;
            text-align: center;
        }

        .signature-line {
            border-bottom: 1px solid #000;
            margin-bottom: 8px;
        }

        .signature-text {
            font-weight: 700;
            font-size: 14px;
            color: #000;
        }

        /* Note Section */
        .note-text {
            font-weight: 700;
            font-size: 14px;
            color: #000;
        }

        /* Print Button */
        .print-btn {
            position: fixed;
            bottom: 30px;
            right: 30px;
            z-index: 1000;
            border-radius: 50px;
            padding: 10px 25px;
            box-shadow: 0 4px 10px rgba(13, 110, 253, 0.4);
        }

        .back-btn {
            position: fixed;
            top: 20px;
            left: 20px;
            z-index: 1000;
        }

        @media print {
            body {
                background: #fff;
                padding: 0;
                margin: 0;
            }

            @page {
                size: A4 portrait;
                /* Standard A4 paper */
                margin: 0;
                /* Remove default page margins */
            }

            .receipt-container {
                margin: 0;
                padding: 10px;
                box-shadow: none;
                max-width: 100%;
                border: 1px solid #000;
                height: 50vh;
                /* Exactly half of the printed page */
                box-sizing: border-box;
                /* Ensure border and padding are within the 50vh */
                overflow: hidden;
                /* Prevent content from spilling over if there is too much */
            }

            .print-btn {
                display: none !important;
            }

            .back-btn {
                display: none !important;
            }

            * {
                -webkit-print-color-adjust: exact !important;
                print-color-adjust: exact !important;
            }

            /* Scale down content slightly to fit everything nicely in half page */
            .institute-name {
                font-size: 24px;
            }

            .institute-address {
                font-size: 12px;
            }

            .info-row,
            .info-group,
            .amount-table th,
            .amount-table td {
                font-size: 12px;
            }

            .signature-section {
                margin-top: 30px;
            }

            h2,
            p,
            .info-value {
                font-size: 90%;
            }
        }
    </style>
</head>

<body>

    <a href="javascript:history.back()" class="btn btn-outline-secondary back-btn"><i
            class="fas fa-arrow-left me-2"></i>Back</a>

    <button onclick="window.print()" class="btn btn-primary print-btn btn-lg">
        <i class="fas fa-print me-2"></i> Print Receipt
    </button>

    <div class="receipt-container">

        <!-- Header -->
        <div class="institute-header">
            <div class="institute-name">CREATIVE DESIGN AND MULTIMEDIA INSTITUTE</div>
            <div class="institute-address">
                401, 4th Floor, City Center, Yogichowk, Surat - 395006.
            </div>
        </div>

        <!-- Bill Label -->
        <div class="bill-header">
            <div class="bill-box">
                Bill of Service
            </div>
        </div>

        <!-- Info Rows -->
        <% const paymentDate=new Date(fee.createdAt); const formattedDate=paymentDate.toLocaleDateString('en-IN', {
            day: '2-digit' , month: '2-digit' , year: 'numeric' }).replace(/\//g, '-' ); const studentName=fee.studentId
            ? `${fee.studentId.surname} ${fee.studentId.studentName} ${fee.studentId.fatherName}`.toUpperCase() : 'N/A'
            ; const courseName=fee.studentId && fee.studentId.courseId ? fee.studentId.courseId.courseName.toUpperCase()
            : 'N/A' ; %>

            <div class="info-row">
                <div>REC. NO : <%= fee.receiptNo %>
                </div>
                <div>DATE : <%= formattedDate %>
                </div>
            </div>

            <div class="info-group">
                STUDENT NAME : <%= studentName %>
            </div>
            <div class="info-group">
                COURSE : <%= courseName %>
            </div>
            <div class="info-group">
                PAYMENT BY : <%= fee.paymentMode.toUpperCase() %>
                    <%= fee.paymentDetails ? '/ ' + fee.paymentDetails.toUpperCase() : '' %>
            </div>

            <!-- Amount Table -->
            <table class="amount-table">
                <thead>
                    <tr>
                        <th class="description-col">DESCRIPTION</th>
                        <th class="amount-col">AMOUNT</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td class="description-col">INSTALLMENT AMOUNT</td>
                        <td class="amount-col">₹<%= fee.amount.toLocaleString('en-IN') %>/-</td>
                    </tr>
                    <tr class="in-words-row">
                        <td colspan="2">
                            <span class="in-words-label">IN WORDS :</span>
                            <span class="in-words-text">
                                <%= amountInWords %>
                            </span>
                            <div style="clear: both;"></div>
                        </td>
                    </tr>
                </tbody>
            </table>

            <!-- Signatures -->
            <div class="signature-section">
                <div class="signature-box">
                    <div class="signature-line"></div>
                    <div class="signature-text">Student's Sign</div>
                </div>
                <div class="signature-box">
                    <div class="signature-line"></div>
                    <div class="signature-text">Receiver's Sign</div>
                </div>
            </div>

            <!-- Note -->
            <div class="note-text">
                Note : Fees will be not refundable in any cases.
            </div>

    </div>

    <!-- Auto Print Script -->
    <script>
        window.onload = function () {
            setTimeout(function () {
                window.print();
            }, 800); // Slight delay for fonts
        }
    </script>
</body>

</html>