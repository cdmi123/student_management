<%- include('../layout/header') %>

    <div class="row mt-3">
        <div class="col-12 d-flex justify-content-between align-items-center mb-3">
            <h4 class="fw-bold mb-0">Multimedia Fees Collections</h4>
        </div>

        <!-- Filter Bar (Optional, can expand later) -->
        <div class="col-12 mb-3">
            <div class="filter-bar shadow-sm">
                <div class="row g-2 align-items-center">
                    <div class="col-md-4">
                        <input type="text" class="form-control" placeholder="Search by Student or Receipt No...">
                    </div>
                    <div class="col-md-3">
                        <select class="form-select">
                            <option value="">Filter by Faculty</option>
                        </select>
                    </div>
                    <div class="col-md-3">
                        <input type="date" class="form-control">
                    </div>
                    <div class="col-md-2 text-end">
                        <span class="fw-bold">Total Records: <%= fees.length %></span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Table Area -->
        <div class="col-12">
            <div class="card shadow-sm border-0">
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table admission-table table-hover mb-0">
                            <thead>
                                <tr>
                                    <th style="width: 50px;">#</th>
                                    <th>RECEIPT NO</th>
                                    <th>STUDENT NAME</th>
                                    <th>FACULTY NAME</th>
                                    <th>INSTALLMENT AMOUNT</th>
                                    <th>PAYMENT MODE</th>
                                    <th>DATE</th>
                                    <th class="text-center">ACTION</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if(fees && fees.length> 0) { %>
                                    <% fees.forEach((fee, index)=> { %>
                                        <tr>
                                            <td class="text-center fw-bold text-muted">
                                                <%= index + 1 %>
                                            </td>
                                            <td class="font-monospace fw-bold text-primary">
                                                <%= fee.receiptNo %>
                                            </td>
                                            <td>
                                                <span class="main-text text-uppercase fw-bold">
                                                    <%= fee.studentId ? fee.studentId.surname + ' ' +
                                                        fee.studentId.studentName : 'N/A' %>
                                                </span>
                                            </td>
                                            <td>
                                                <span class="main-text">
                                                    <%= fee.facultyId ? fee.facultyId.name : 'N/A' %>
                                                </span>
                                            </td>
                                            <td class="font-monospace fw-bold text-success">
                                                ₹<%= fee.amount %>
                                            </td>
                                            <td>
                                                <span class="badge bg-secondary">
                                                    <%= fee.paymentMode %>
                                                </span>
                                                <% if(fee.paymentDetails) { %>
                                                    <br><small class="text-muted">
                                                        <%= fee.paymentDetails %>
                                                    </small>
                                                    <% } %>
                                            </td>
                                            <td>
                                                <%= new Date(fee.createdAt).toLocaleDateString('en-IN', {day:'2-digit',
                                                    month:'2-digit', year:'numeric'}).replace(/\//g, '-' ) %>
                                            </td>
                                            <td class="text-center align-middle">
                                                <a href="/fee/receipt/<%= fee._id %>" target="_blank"
                                                    class="btn btn-primary btn-sm rounded-pill shadow-sm"
                                                    title="Print Receipt">
                                                    <i class="fas fa-print me-1"></i> Print
                                                </a>
                                            </td>
                                        </tr>
                                        <% }) %>
                                            <% } else { %>
                                                <tr>
                                                    <td colspan="8" class="text-center py-5">
                                                        <i class="fas fa-receipt fa-2x mb-2 text-light"></i><br>
                                                        <h5 class="text-muted">No fee records found</h5>
                                                    </td>
                                                </tr>
                                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
        // Highlight sidebar active link
        document.querySelectorAll('#sidebar ul li a').forEach(el => {
            if (el.getAttribute('href') === '/fee/list') {
                el.closest('ul').classList.add('show');
                el.parentElement.classList.add('active');
            }
        });
    </script>

    <%- include('../layout/footer') %>