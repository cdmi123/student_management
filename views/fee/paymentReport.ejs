<%- include('../layout/header') %>

    <!-- Google Fonts: Outfit -->
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <style>
        :root {
            --primary-gradient: linear-gradient(135deg, #6366f1 0%, #4f46e5 100%);
            --success-gradient: linear-gradient(135deg, #34d399 0%, #10b981 100%);
            --info-gradient: linear-gradient(135deg, #38bdf8 0%, #0ea5e9 100%);
            --warning-gradient: linear-gradient(135deg, #fbbf24 0%, #f59e0b 100%);
            --surface-card: #ffffff;
            --text-main: #1e293b;
            --text-muted: #64748b;
            --bg-main: #f8fafc;
            --border-color: #e2e8f0;
        }

        body {
            font-family: 'Outfit', sans-serif;
            background-color: var(--bg-main);
            color: var(--text-main);
        }

        .report-container {
            animation: fadeIn 0.6s ease-out;
        }

        @keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(10px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /* Header Styling */
        .page-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 2rem;
        }

        .page-title {
            font-weight: 700;
            font-size: 1.75rem;
            letter-spacing: -0.02em;
            margin: 0;
            background: var(--primary-gradient);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        /* Filter Section */
        .filter-card {
            background: var(--surface-card);
            border: 1px solid var(--border-color);
            border-radius: 16px;
            padding: 1.5rem;
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
            margin-bottom: 2rem;
        }

        .filter-label {
            font-weight: 600;
            font-size: 0.85rem;
            color: var(--text-muted);
            text-transform: uppercase;
            margin-bottom: 0.5rem;
        }

        .form-control,
        .form-select {
            border-radius: 10px;
            border: 1px solid var(--border-color);
            padding: 0.6rem 1rem;
            font-size: 0.95rem;
            transition: all 0.2s;
        }

        .form-control:focus,
        .form-select:focus {
            border-color: #6366f1;
            box-shadow: 0 0 0 4px rgba(99, 102, 241, 0.1);
        }

        /* Stats Cards */
        .stat-card {
            border-radius: 16px;
            padding: 1.5rem;
            border: none;
            color: white;
            height: 100%;
            position: relative;
            overflow: hidden;
            transition: transform 0.3s;
        }

        .stat-card:hover {
            transform: translateY(-5px);
        }

        .stat-card::after {
            content: '';
            position: absolute;
            top: -50%;
            right: -50%;
            width: 150px;
            height: 150px;
            background: rgba(255, 255, 255, 0.1);
            border-radius: 50%;
        }

        .stat-card.primary {
            background: var(--primary-gradient);
        }

        .stat-card.success {
            background: var(--success-gradient);
        }

        .stat-card.info {
            background: var(--info-gradient);
        }

        .stat-label {
            font-weight: 500;
            font-size: 0.9rem;
            opacity: 0.9;
            margin-bottom: 0.25rem;
        }

        .stat-value {
            font-weight: 700;
            font-size: 1.8rem;
        }

        /* Table Styling */
        .table-container {
            background: var(--surface-card);
            border-radius: 16px;
            border: 1px solid var(--border-color);
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
            overflow: hidden;
        }

        .table thead th {
            background: #f1f5f9;
            padding: 1rem 1.5rem;
            font-weight: 600;
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            color: var(--text-muted);
            border: none;
        }

        .table tbody td {
            padding: 1.25rem 1.5rem;
            vertical-align: middle;
            border-bottom: 1px solid var(--border-color);
        }

        .table tbody tr:last-child td {
            border-bottom: none;
        }

        .table hover:hover {
            background-color: #f8fafc;
        }

        /* Badge & Utilities */
        .badge-receipt {
            background: #f1f5f9;
            color: #475569;
            font-weight: 600;
            padding: 0.5em 1em;
            border-radius: 8px;
            font-family: monospace;
        }

        .badge-mode {
            padding: 0.4em 0.8em;
            font-weight: 600;
            border-radius: 6px;
            font-size: 0.75rem;
        }

        .mode-cash {
            background: #dcfce7;
            color: #166534;
        }

        .mode-upi {
            background: #e0e7ff;
            color: #3730a3;
        }

        .mode-cheque {
            background: #fef9c3;
            color: #854d0e;
        }

        .amount-text {
            font-weight: 700;
            color: var(--text-main);
            font-size: 1.05rem;
        }

        .btn-print {
            background: white;
            color: var(--text-main);
            border: 1px solid var(--border-color);
            border-radius: 10px;
            padding: 0.6rem 1.25rem;
            font-weight: 600;
            transition: all 0.2s;
        }

        .btn-print:hover {
            background: #f8fafc;
            border-color: #cbd5e1;
        }

        .btn-filter {
            background: #1e293b;
            color: white;
            border: none;
            border-radius: 10px;
            padding: 0.6rem 1.25rem;
            font-weight: 600;
        }

        .btn-filter:hover {
            background: #0f172a;
            color: white;
        }

        @media print {
            .no-print {
                display: none !important;
            }

            .page-content {
                padding: 0 !important;
            }

            .table-container {
                box-shadow: none;
                border: 1px solid #eee;
            }

            body {
                background: white;
            }
        }
    </style>

    <div class="report-container px-4 py-4" id="reportRoot">
        <!-- Header -->
        <div class="page-header no-print">
            <div>
                <h1 class="page-title">Financial Report</h1>
                <p class="text-muted mb-0">Track and manage your payment collections</p>
            </div>
            <div class="d-flex gap-2">
                <a href="/fee/list" class="btn btn-print">
                    <i class="fas fa-list me-2"></i>History
                </a>
                <button class="btn btn-print" onclick="window.print()">
                    <i class="fas fa-print me-2"></i>Export PDF
                </button>
            </div>
        </div>

        <!-- Filter Card -->
        <div class="filter-card no-print">
            <form id="filterForm">
                <div class="row g-3">
                    <div class="col-md-3">
                        <div class="filter-label">Filter by Single Day</div>
                        <input type="date" name="date" id="filterDate" class="form-control" value="<%= filters.date %>">
                    </div>

                    <div class="col-md-1 d-flex flex-column justify-content-center text-center">
                        <span class="text-muted fw-bold small mt-3">OR</span>
                    </div>

                    <div class="col-md-3">
                        <div class="filter-label">Select Month</div>
                        <select name="month" id="filterMonth" class="form-select">
                            <option value="">Choose Month...</option>
                            <% const months=['January', 'February' , 'March' , 'April' , 'May' , 'June' , 'July'
                                , 'August' , 'September' , 'October' , 'November' , 'December' ]; %>
                                <% months.forEach((m, i)=> { %>
                                    <option value="<%= i + 1 %>" <%=filters.month==(i + 1) ? 'selected' : '' %>><%= m %>
                                    </option>
                                    <% }) %>
                        </select>
                    </div>

                    <div class="col-md-2">
                        <div class="filter-label">Select Year</div>
                        <select name="year" id="filterYear" class="form-select">
                            <% const currentYear=new Date().getFullYear(); %>
                                <option value="">Year...</option>
                                <% for(let y=currentYear; y>= currentYear - 5; y--) { %>
                                    <option value="<%= y %>" <%=filters.year==y ? 'selected' : ( (!filters.year &&
                                        y==currentYear) ? 'selected' : '' ) %>><%= y %>
                                    </option>
                                    <% } %>
                        </select>
                    </div>

                    <div class="col-md-3 d-flex align-items-end gap-2">
                        <button type="submit" class="btn btn-filter flex-grow-1">
                            <i class="fas fa-search me-2"></i>Apply Analytics
                        </button>
                        <a href="/fee/report" class="btn btn-print">
                            <i class="fas fa-redo"></i>
                        </a>
                    </div>
                </div>
            </form>
        </div>

        <!-- Info Banner -->
        <div class="mb-4 d-flex align-items-center justify-content-between">
            <div class="d-flex align-items-center">
                <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center me-3"
                    style="width: 40px; height: 40px;">
                    <i class="fas fa-calendar-check" id="bannerIcon"></i>
                </div>
                <div>
                    <h5 class="mb-0 fw-bold" id="reportTitle">
                        <% if(filters.date) { %>
                            Collections for <%= new Date(filters.date).toLocaleDateString('en-IN', { day: 'numeric' ,
                                month: 'long' , year: 'numeric' }) %>
                                <% } else if(filters.month && filters.year) { %>
                                    Monthly Report: <%= months[filters.month-1] %>
                                        <%= filters.year %>
                                            <% } else if(filters.year) { %>
                                                Yearly Summary: <%= filters.year %>
                                                    <% } else { %>
                                                        Full Analytics Overview
                                                        <% } %>
                    </h5>
                    <span class="text-muted small">Generated on <span id="generationTime">
                            <%= new Date().toLocaleDateString('en-IN', { hour: '2-digit' , minute: '2-digit' }) %>
                        </span></span>
                </div>
            </div>
            <div class="no-print">
                <div id="statusBadgeContainer">
                    <% if(fees.length> 0) { %>
                        <span class="badge bg-success-subtle text-success px-3 py-2 rounded-pill">
                            <i class="fas fa-check-circle me-1"></i> Data Computed Successfully
                        </span>
                        <% } %>
                </div>
            </div>
        </div>

        <!-- Stats Row -->
        <div class="row g-4 mb-5" id="statsRow">
            <div class="col-md-4">
                <div class="stat-card primary">
                    <div class="stat-label">Gross Collection</div>
                    <div class="stat-value" id="statGross">₹<%= totalCollection.toLocaleString('en-IN') %>
                    </div>
                    <div class="small mt-2 opacity-75">
                        <i class="fas fa-arrow-up me-1"></i> Total volume for selected period
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="stat-card success">
                    <div class="stat-label">Total Transactions</div>
                    <div class="stat-value" id="statCount">
                        <%= fees.length %>
                    </div>
                    <div class="small mt-2 opacity-75">
                        <i class="fas fa-receipt me-1"></i> Individual payments processed
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="stat-card info">
                    <div class="stat-label">Avg. Payment</div>
                    <div class="stat-value" id="statAvg">₹<%= fees.length> 0 ? (totalCollection /
                            fees.length).toLocaleString('en-IN', {maximumFractionDigits: 0}) : 0 %></div>
                    <div class="small mt-2 opacity-75">
                        <i class="fas fa-chart-line me-1"></i> Per receipt average
                    </div>
                </div>
            </div>
        </div>

        <!-- Table Section -->
        <div class="table-container position-relative">
            <div id="loadingOverlay"
                class="position-absolute top-0 start-0 w-100 h-100 bg-white bg-opacity-75 d-none align-items-center justify-content-center"
                style="z-index: 10;">
                <div class="spinner-border text-primary" role="status">
                    <span class="visually-hidden">Loading...</span>
                </div>
            </div>
            <table class="table mb-0" id="feeTable">
                <thead>
                    <tr>
                        <th class="text-center" style="width: 80px;">S.No</th>
                        <th>Date</th>
                        <th>Receipt Info</th>
                        <th>Student Details</th>
                        <th>Method</th>
                        <th class="text-end">Amount</th>
                    </tr>
                </thead>
                <tbody>
                    <% if(fees && fees.length> 0) { %>
                        <% fees.forEach((fee, index)=> { %>
                            <tr>
                                <td class="text-center text-muted small">
                                    <%= index + 1 %>
                                </td>
                                <td class="fw-medium">
                                    <%= new Date(fee.date).toLocaleDateString('en-IN') %>
                                </td>
                                <td>
                                    <span class="badge-receipt">
                                        <%= fee.receiptNo %>
                                    </span>
                                </td>
                                <td>
                                    <div class="fw-bold">
                                        <%= fee.studentId ? (fee.studentId.surname + ' ' + fee.studentId.studentName)
                                            : 'N/A' %>
                                    </div>
                                    <div class="small text-muted">
                                        <%= fee.registrationNo %>
                                    </div>
                                </td>
                                <td>
                                    <% let modeClass='mode-cash' ; if(fee.paymentMode==='UPI' ) modeClass='mode-upi' ;
                                        if(fee.paymentMode==='Cheque' ) modeClass='mode-cheque' ; %>
                                        <span class="badge-mode <%= modeClass %>">
                                            <%= fee.paymentMode %>
                                        </span>
                                </td>
                                <td class="text-end">
                                    <span class="amount-text">₹<%= fee.amount.toLocaleString('en-IN') %></span>
                                </td>
                            </tr>
                            <% }) %>
                                <% } else { %>
                                    <tr>
                                        <td colspan="6" class="text-center py-5">
                                            <div class="text-muted my-3">
                                                <i class="fas fa-folder-open fa-3x mb-3 opacity-25"></i>
                                                <p class="h5">No Transactions Found</p>
                                                <p class="small">Try adjusting your filters to see more results</p>
                                            </div>
                                        </td>
                                    </tr>
                                    <% } %>
                </tbody>
                <tfoot class="bg-light <%= fees.length > 0 ? '' : 'd-none' %>" id="feeTableFooter">
                    <tr>
                        <td colspan="5" class="text-end py-4 fw-bold text-muted">SUMMARY TOTAL:</td>
                        <td class="text-end py-4">
                            <span class="h4 fw-bold text-primary mb-0" id="summaryTotal">₹<%=
                                    totalCollection.toLocaleString('en-IN') %></span>
                        </td>
                    </tr>
                </tfoot>
            </table>
        </div>
    </div>

    <script>
        const filterForm = document.getElementById('filterForm');
        const loadingOverlay = document.getElementById('loadingOverlay');
        const feeTableBody = document.querySelector('#feeTable tbody');
        const feeTableFooter = document.getElementById('feeTableFooter');

        // Elements to update
        const statGross = document.getElementById('statGross');
        const statCount = document.getElementById('statCount');
        const statAvg = document.getElementById('statAvg');
        const summaryTotal = document.getElementById('summaryTotal');
        const reportTitle = document.getElementById('reportTitle');
        const statusBadgeContainer = document.getElementById('statusBadgeContainer');
        const generationTime = document.getElementById('generationTime');

        async function updateReport(e) {
            if (e) e.preventDefault();

            // If the event came from month change, clear date
            if (e && e.target && e.target.id === 'filterMonth' && e.target.value) {
                document.getElementById('filterDate').value = '';
            }
            // If the event came from date change, clear month
            if (e && e.target && e.target.id === 'filterDate' && e.target.value) {
                document.getElementById('filterMonth').value = '';
            }

            const formData = new FormData(filterForm);
            const params = new URLSearchParams(formData);

            // Update URL without refresh
            const newUrl = `${window.location.pathname}?${params.toString()}`;
            window.history.pushState({ path: newUrl }, '', newUrl);

            loadingOverlay.classList.replace('d-none', 'd-flex');

            try {
                const response = await fetch(`/fee/api/report?${params.toString()}`);
                const data = await response.json();

                renderData(data);
            } catch (error) {
                console.error('Error fetching report:', error);
            } finally {
                loadingOverlay.classList.replace('d-flex', 'd-none');
            }
        }

        function renderData(data) {
            const { fees, totalCollection, filters } = data;
            const months = ['January', 'February', 'March', 'April', 'May', 'June', 'July', 'August', 'September', 'October', 'November', 'December'];

            // Update Stats
            statGross.innerText = `₹${totalCollection.toLocaleString('en-IN')}`;
            statCount.innerText = fees.length;
            statAvg.innerText = `₹${fees.length > 0 ? (totalCollection / fees.length).toLocaleString('en-IN', { maximumFractionDigits: 0 }) : 0}`;
            summaryTotal.innerText = `₹${totalCollection.toLocaleString('en-IN')}`;

            // Update Title
            let titleText = 'Full Analytics Overview';
            if (filters.date) {
                const d = new Date(filters.date);
                titleText = `Collections for ${d.toLocaleDateString('en-IN', { day: 'numeric', month: 'long', year: 'numeric' })}`;
            } else if (filters.month && filters.year) {
                titleText = `Monthly Report: ${months[filters.month - 1]} ${filters.year}`;
            } else if (filters.year) {
                titleText = `Yearly Summary: ${filters.year}`;
            }
            reportTitle.innerText = titleText;
            generationTime.innerText = new Date().toLocaleDateString('en-IN', { hour: '2-digit', minute: '2-digit' });

            // Update Badge
            statusBadgeContainer.innerHTML = fees.length > 0 ? `
            <span class="badge bg-success-subtle text-success px-3 py-2 rounded-pill">
                <i class="fas fa-check-circle me-1"></i> Data Computed Successfully
            </span>` : '';

            // Update Table
            feeTableBody.innerHTML = '';
            if (fees.length > 0) {
                feeTableFooter.classList.remove('d-none');
                fees.forEach((fee, index) => {
                    let modeClass = 'mode-cash';
                    if (fee.paymentMode === 'UPI') modeClass = 'mode-upi';
                    if (fee.paymentMode === 'Cheque') modeClass = 'mode-cheque';

                    const row = `
                    <tr>
                        <td class="text-center text-muted small">${index + 1}</td>
                        <td class="fw-medium">${new Date(fee.date).toLocaleDateString('en-IN')}</td>
                        <td><span class="badge-receipt">${fee.receiptNo}</span></td>
                        <td>
                            <div class="fw-bold">${fee.studentId ? (fee.studentId.surname + ' ' + fee.studentId.studentName) : 'N/A'}</div>
                            <div class="small text-muted">${fee.registrationNo}</div>
                        </td>
                        <td><span class="badge-mode ${modeClass}">${fee.paymentMode}</span></td>
                        <td class="text-end"><span class="amount-text">₹${fee.amount.toLocaleString('en-IN')}</span></td>
                    </tr>
                `;
                    feeTableBody.insertAdjacentHTML('beforeend', row);
                });
            } else {
                feeTableFooter.classList.add('d-none');
                feeTableBody.innerHTML = `
                <tr>
                    <td colspan="6" class="text-center py-5">
                        <div class="text-muted my-3">
                            <i class="fas fa-folder-open fa-3x mb-3 opacity-25"></i>
                            <p class="h5">No Transactions Found</p>
                            <p class="small">Try adjusting your filters to see more results</p>
                        </div>
                    </td>
                </tr>
            `;
            }
        }

        // Attach Event Listeners
        filterForm.addEventListener('submit', updateReport);
        document.getElementById('filterDate').addEventListener('change', updateReport);
        document.getElementById('filterMonth').addEventListener('change', updateReport);
        document.getElementById('filterYear').addEventListener('change', updateReport);
    </script>

    <%- include('../layout/footer') %>