<%- include('../layout/header') %>

    <div class="row">
        <div class="col-12 px-0">
            <div class="form-header-bar mt-2">
                <h5 class="mb-0 text-white">
                    <i class="fas fa-list me-2"></i> All Available Courses
                </h5>
                <a href="/course/add" class="btn btn-sm btn-light text-primary fw-bold px-3">
                    <i class="fas fa-plus me-2"></i> Add New Course
                </a>
            </div>

            <div class="form-content-area shadow-sm mb-5">
                <div class="table-responsive">
                    <table class="table table-hover align-middle" id="dataTable">
                        <thead class="table-light">
                            <tr>
                                <th style="width: 50px;">#</th>
                                <th>Course Name</th>
                                <th>Duration</th>
                                <th>Total Fees</th>
                                <th>Content Overview</th>
                                <th class="text-center" style="width: 120px;">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if(courses && courses.length> 0) { %>
                                <% courses.forEach((course, index)=> { %>
                                    <tr>
                                        <td class="text-muted fw-bold">
                                            <%= index + 1 %>
                                        </td>
                                        <td>
                                            <div class="fw-bold text-primary"><%= course.courseName %></div>
                                        </td>
                                        <td>
                                            <span class="badge bg-light text-dark border"><%= course.duration %></span>
                                        </td>
                                        <td class="fw-bold text-dark">
                                            ₹<%= course.fees.toLocaleString('en-IN') %>
                                        </td>
                                        <td>
                                            <div class="text-truncate" style="max-width: 250px;" title="<%= course.content %>">
                                                <%= course.content %>
                                            </div>
                                        </td>
                                        <td class="text-center">
                                            <div class="d-flex justify-content-center gap-2">
                                                <a href="/course/edit/<%= course._id %>" class="btn btn-sm btn-outline-primary" title="Edit">
                                                    <i class="fas fa-edit"></i>
                                                </a>
                                                <form action="/course/delete/<%= course._id %>" method="POST"
                                                    class="d-inline"
                                                    onsubmit="return confirm('Are you sure you want to delete this course?');">
                                                    <button type="submit" class="btn btn-sm btn-outline-danger" title="Delete">
                                                        <i class="fas fa-trash"></i>
                                                    </button>
                                                </form>
                                            </div>
                                        </td>
                                    </tr>
                                    <% }) %>
                            <% } else { %>
                                <tr>
                                    <td colspan="6" class="text-center py-5">
                                        <div class="text-muted mb-3">
                                            <i class="fas fa-folder-open fa-3x"></i>
                                        </div>
                                        <h5 class="text-muted">No courses found</h5>
                                        <a href="/course/add" class="btn btn-primary mt-2">Add your first course</a>
                                    </td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <script>
        // Highlight sidebar active link
        document.querySelectorAll('#sidebar ul li a').forEach(el => {
            if (el.getAttribute('href') === '/course/list') {
                el.parentElement.classList.add('active');
            }
        });
    </script>

    <%- include('../layout/footer') %>