<%- include('../layout/header') %>

    <div class="row">
        <div class="col-12">
            <div class="form-header-bar mt-3">
                <h5 class="mb-0 text-white">
                    <i class="fas fa-book-open me-2"></i>
                    <%= typeof isEdit !=='undefined' && isEdit ? 'Edit Course Details' : 'Add New Course' %>
                </h5>
                <a href="/course/list" class="btn btn-sm btn-light text-primary fw-bold px-3">
                    <i class="fas fa-list me-2"></i> Course List
                </a>
            </div>

            <div class="form-content-area shadow-sm mb-5">
                <% if (typeof error !=='undefined' ) { %>
                    <div class="alert alert-danger alert-dismissible fade show mb-4" role="alert">
                        <i class="fas fa-exclamation-circle me-2"></i>
                        <%= error %>
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                    <% } %>

                        <form
                            action="<%= typeof isEdit !== 'undefined' && isEdit ? '/course/edit/' + course._id : '/course/add' %>"
                            method="POST">
                            <div class="row mb-4">
                                <div class="col-md-4">
                                    <label for="courseName" class="form-label">Course Name*</label>
                                    <input type="text" class="form-control" id="courseName" name="courseName" required
                                        value="<%= typeof course !== 'undefined' ? course.courseName : '' %>"
                                        placeholder="e.g. Master in Web Development">
                                </div>
                                <div class="col-md-4">
                                    <label for="duration" class="form-label">Course Duration*</label>
                                    <input type="text" class="form-control" id="duration" name="duration" required
                                        value="<%= typeof course !== 'undefined' ? course.duration : '' %>"
                                        placeholder="e.g. 6 Months">
                                </div>
                                <div class="col-md-4">
                                    <label for="fees" class="form-label">Total Fees (₹)*</label>
                                    <div class="input-group">
                                        <span class="input-group-text bg-light text-muted">₹</span>
                                        <input type="number" class="form-control" id="fees" name="fees" required min="0"
                                            step="500" value="<%= typeof course !== 'undefined' ? course.fees : '' %>"
                                            placeholder="e.g. 25000">
                                    </div>
                                </div>
                            </div>

                            <div class="row mb-4">
                                <div class="col-md-12">
                                    <label for="content" class="form-label">Course Content*</label>
                                    <textarea class="form-control form-control-sm" id="content" name="content" rows="2" required
                                        placeholder="Briefly describe what will be covered..."><%= typeof course !== 'undefined' ? course.content : '' %></textarea>
                                </div>
                            </div>

                            <div class="text-end border-top pt-4">
                                <a href="/course/list" class="btn btn-outline-secondary px-4 me-2">
                                    Cancel
                                </a>
                                <button type="submit" class="btn btn-primary-theme px-5">
                                    <i class="fas fa-save me-2"></i>
                                    <%= typeof isEdit !=='undefined' && isEdit ? 'Update Course' : 'Save Course' %>
                                </button>
                            </div>
                        </form>
            </div>
        </div>
    </div>

    <script>
        // Highlight sidebar active link
        document.querySelectorAll('#sidebar ul li a').forEach(el => {
            if (el.getAttribute('href') === '/course/add') {
                el.parentElement.classList.add('active');
            }
        });
    </script>

    <%- include('../layout/footer') %>