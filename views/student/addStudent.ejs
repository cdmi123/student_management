<%- include('../layout/header') %>

    <div class="form-header-bar mt-2">
        <h5>New Course Admission</h5>
        <a href="/student/list" class="btn btn-sm btn-light"><i class="fas fa-list me-2"></i>Admission List</a>
    </div>

    <div class="tab-container">
        <ul class="nav nav-tabs nav-tabs-custom" id="formTabs" role="tablist">
            <li class="nav-item" role="presentation">
                <button class="nav-link active" id="student-tab" data-bs-toggle="tab" data-bs-target="#student-info" type="button" role="tab">Student Information</button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="course-tab" data-bs-toggle="tab" data-bs-target="#course-info" type="button" role="tab">Course Information</button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="faculty-tab" data-bs-toggle="tab" data-bs-target="#faculty-info" type="button" role="tab">Faculty Information</button>
            </li>
        </ul>
    </div>

    <% if (typeof error !=='undefined' ) { %>
        <div class="alert alert-danger mt-3">
            <%= error %>
        </div>
        <% } %>

            <form action="/student/add" method="POST" enctype="multipart/form-data" id="studentForm" class="form-content-area shadow-sm mb-5">
                <div class="tab-content" id="formTabsContent">
                    <!-- Student Information Tab -->
                    <div class="tab-pane fade show active" id="student-info" role="tabpanel">
                        <h4 class="section-title">Personal Information</h4>
                        
                        <div class="row mb-4">
                            <div class="col-md-4">
                                <label class="form-label">Surname*</label>
                                <input type="text" class="form-control" name="surname" placeholder="Enter Surname" required>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Student Name*</label>
                                <input type="text" class="form-control" name="studentName" placeholder="Enter Student Name" required>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Father Name*</label>
                                <input type="text" class="form-control" name="fatherName" placeholder="Enter Father Name" required>
                            </div>
                        </div>

                        <div class="row mb-4">
                            <div class="col-md-4">
                                <label class="form-label">Student Contact No*</label>
                                <input type="text" class="form-control" name="studentContact" placeholder="Enter Student Contact No" required>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Parents Contact No*</label>
                                <input type="text" class="form-control" name="parentsContact" placeholder="Enter Parents Contact No" required>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Date of Birth (DOB)*</label>
                                <input type="date" class="form-control" name="dob" required>
                            </div>
                        </div>

                        <div class="row mb-4">
                            <div class="col-md-8">
                                <label class="form-label">Address*</label>
                                <textarea class="form-control" name="address" placeholder="Enter Address" rows="1" required></textarea>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Qualification*</label>
                                <input type="text" class="form-control" name="qualification" placeholder="Enter Qualification" required>
                            </div>
                        </div>

                        <div class="row mb-4">
                            <div class="col-md-4">
                                <label class="form-label">Student Reference*</label>
                                <select class="form-select" name="referenceType" required>
                                    <option value="">Select Reference</option>
                                    <option value="Others">Others</option>
                                    <option value="Internet">Internet</option>
                                    <option value="Student">Student</option>
                                    <option value="Staff">Staff</option>
                                    <option value="Seminar">Seminar</option>
                                </select>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Reference Name*</label>
                                <input type="text" class="form-control" name="referenceName" placeholder="Enter Reference Name">
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Student Image</label>
                                <div class="image-upload-box">
                                    <input type="text" class="form-control bg-light" placeholder="Choose file" readonly>
                                    <button type="button" class="btn btn-upload px-3">Browse</button>
                                    <input type="file" class="d-none" name="image" id="imageInput" accept="image/*">
                                </div>
                            </div>
                        </div>

                        <div class="row mb-4">
                            <div class="col-md-12">
                                <div id="imagePreviewContainer" class="d-none mb-2">
                                    <img id="imagePreview" src="" alt="Preview" class="img-thumbnail" style="max-height: 100px;">
                                </div>
                            </div>
                            <div class="col-md-12 text-end">
                                <button type="button" class="btn btn-primary px-4 next-tab" data-next="course-info">
                                    Next: Course Info <i class="fas fa-arrow-right ms-2"></i>
                                </button>
                            </div>
                        </div>
                    </div>

                    <!-- Course Information Tab -->
                    <div class="tab-pane fade" id="course-info" role="tabpanel">
                        <h4 class="section-title">Course Information</h4>
                        <div class="row mb-4">
                            <div class="col-md-12">
                                <label class="form-label">Course Selection*</label>
                                <select class="form-select" name="courseId" id="courseSelect" required>
                                    <option value="">Select a course...</option>
                                    <% courses.forEach(course=> { %>
                                        <option value="<%= course._id %>">
                                            <%= course.courseName %>
                                        </option>
                                        <% }) %>
                                </select>
                            </div>
                        </div>
                        <div class="row mb-4">
                            <div class="col-md-4">
                                <label class="form-label">Course Duration</label>
                                <input type="text" class="form-control bg-light" name="courseDuration" id="courseDuration" readonly>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Total Fees (₹)*</label>
                                <input type="number" class="form-control bg-light" name="totalFees" id="totalFees" readonly required>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Daily Time</label>
                                <select class="form-select" name="dailyTime">
                                    <option value="1H">1H</option>
                                    <option value="2H">2H</option>
                                    <option value="3H">3H</option>
                                    <option value="4H">4H</option>
                                    <option value="6H">6H</option>
                                </select>
                            </div>
                        </div>
                        
                        <div class="mb-4">
                            <label class="form-label">Course Content</label>
                            <textarea class="form-control bg-light" name="courseContent" id="courseContent" rows="3" readonly></textarea>
                        </div>
                        
                        <hr>
                        <div class="d-flex align-items-center justify-content-between mb-3">
                            <h5 class="mb-0">Installment Details</h5>
                            <div class="d-flex align-items-center gap-2">
                                <div class="input-group input-group-sm" style="width: 250px;">
                                    <span class="input-group-text bg-light text-muted">Installment Amount</span>
                                    <input type="number" class="form-control" id="standardInstallment" placeholder="₹">
                                    <button type="button" class="btn btn-primary" id="autoGenerateBtn">
                                        <i class="fas fa-magic"></i> Generate
                                    </button>
                                </div>
                            </div>
                        </div>

                        <div class="table-responsive">
                            <table class="table table-bordered" id="installmentTable">
                                <thead class="table-light">
                                    <tr>
                                        <th style="width: 80px;">No.</th>
                                        <th>Amount (₹)</th>
                                        <th>Date</th>
                                        <th style="width: 80px;">Action</th>
                                    </tr>
                                </thead>
                                <tbody id="installmentBody">
                                </tbody>
                                <tfoot>
                                    <tr>
                                        <th class="text-end">Total:</th>
                                        <th><span id="installmentTotal">0</span></th>
                                        <th colspan="2">
                                            <div class="d-flex justify-content-between align-items-center">
                                                <small id="installmentWarning" class="text-danger d-none fw-bold">
                                                    <i class="fas fa-exclamation-triangle"></i> Total doesn't match Course Fees!
                                                </small>
                                                <button type="button" class="btn btn-sm btn-outline-success ms-auto" id="addInstallmentBtn">
                                                    <i class="fas fa-plus me-1"></i> Add Manually
                                                </button>
                                            </div>
                                        </th>
                                    </tr>
                                </tfoot>
                            </table>
                        </div>

                        <div class="row mt-4">
                            <div class="col-md-12 text-end">
                                <button type="button" class="btn btn-primary px-4 next-tab" data-next="faculty-tab">
                                    Next: Faculty Info <i class="fas fa-arrow-right ms-2"></i>
                                </button>
                            </div>
                        </div>
                    </div>

                    <!-- Faculty Information Tab -->
                    <div class="tab-pane fade" id="faculty-info" role="tabpanel">
                        <h4 class="section-title">Faculty Information</h4>
                        <div class="row mb-4">
                            <div class="col-md-6">
                                <label class="form-label">Select Faculty*</label>
                                <select class="form-select" name="facultyName" required>
                                    <option value="">Select Faculty</option>
                                    <option value="Hitesh Sir">Hitesh Sir</option>
                                    <option value="Mayur Sir">Mayur Sir</option>
                                    <option value="Vivek Sir">Vivek Sir</option>
                                    <option value="Rajesh Sir">Rajesh Sir</option>
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Batch Time*</label>
                                <select class="form-select" name="batchTime" required>
                                    <option value="">Select Batch Time</option>
                                    <option value="8 To 10">8 To 10</option>
                                    <option value="10 To 12">10 To 12</option>
                                    <option value="12 To 2">12 To 2</option>
                                    <option value="2 To 4">2 To 4</option>
                                    <option value="4 To 6">4 To 6</option>
                                    <option value="6 To 8">6 To 8</option>
                                </select>
                            </div>
                        </div>
                        <div class="row mb-4">
                            <div class="col-md-6">
                                <label class="form-label">Running Topic*</label>
                                <input type="text" class="form-control" name="runningTopic" placeholder="Enter Current Topic" required>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Extra Note</label>
                                <textarea class="form-control" name="extraNote" placeholder="Any additional notes..." rows="1"></textarea>
                            </div>
                        </div>

                        <div class="text-end border-top pt-4">
                            <button type="submit" class="btn btn-primary-theme px-5" id="submitBtn">
                                <i class="fas fa-save me-2"></i> Register Student
                            </button>
                        </div>
                    </div>
                </div>
            </form>

            <script>
                // 1. Browse Button Trigger
                document.querySelector('.btn-upload').addEventListener('click', function() {
                    document.getElementById('imageInput').click();
                });
                // 3. Image Preview & Drag and Drop
                const uploadBox = document.querySelector('.image-upload-box');
                const imageInput = document.getElementById('imageInput');
                const fileNameInput = uploadBox.querySelector('.form-control');
                const previewContainer = document.getElementById('imagePreviewContainer');
                const previewImage = document.getElementById('imagePreview');

                function handleFiles(files) {
                    const file = files[0];
                    if (file && file.type.startsWith('image/')) {
                        fileNameInput.value = file.name;
                        
                        // Create a DataTransfer object to sync the file input
                        const dataTransfer = new DataTransfer();
                        dataTransfer.items.add(file);
                        imageInput.files = dataTransfer.files;

                        const reader = new FileReader();
                        reader.onload = function (e) {
                            previewImage.src = e.target.result;
                            previewContainer.classList.remove('d-none');
                        }
                        reader.readAsDataURL(file);
                    } else if (file) {
                        alert('Please drop an image file.');
                    } else {
                        fileNameInput.value = '';
                        previewContainer.classList.add('d-none');
                    }
                }

                imageInput.addEventListener('change', function (e) {
                    handleFiles(this.files);
                });

                // Drag and Drop Events
                ['dragenter', 'dragover', 'dragleave', 'drop'].forEach(eventName => {
                    uploadBox.addEventListener(eventName, preventDefaults, false);
                });

                function preventDefaults(e) {
                    e.preventDefault();
                    e.stopPropagation();
                }

                ['dragenter', 'dragover'].forEach(eventName => {
                    uploadBox.addEventListener(eventName, () => {
                        uploadBox.classList.add('drag-over');
                    }, false);
                });

                ['dragleave', 'drop'].forEach(eventName => {
                    uploadBox.addEventListener(eventName, () => {
                        uploadBox.classList.remove('drag-over');
                    }, false);
                });

                uploadBox.addEventListener('drop', (e) => {
                    const dt = e.dataTransfer;
                    const files = dt.files;
                    handleFiles(files);
                });

                // 3. Disable Sunday Selection in Date Fields
                function applySundayBlocker() {
                    const dateInputs = document.querySelectorAll('input[type="date"].disable-sunday');
                    dateInputs.forEach(input => {
                        input.addEventListener('input', function (e) {
                            const day = new Date(this.value).getUTCDay();
                            if ([0].includes(day)) { // 0 is Sunday
                                e.preventDefault();
                                this.value = '';
                                alert('Sundays are not selectable!');
                            }
                        });
                    });
                }
                applySundayBlocker();

                // 4. AJAX Course Selection
                document.getElementById('courseSelect').addEventListener('change', function () {
                    const courseId = this.value;
                    if (!courseId) {
                        document.getElementById('courseDuration').value = '';
                        document.getElementById('totalFees').value = '';
                        document.getElementById('courseContent').value = '';
                        document.getElementById('targetFees').innerText = '0';
                        validateInstallments();
                        return;
                    }

                    fetch(`/course/api/${courseId}`)
                        .then(res => res.json())
                        .then(data => {
                            document.getElementById('courseDuration').value = data.duration || '';
                            document.getElementById('totalFees').value = data.fees || '';
                            document.getElementById('courseContent').value = data.content || '';
                            document.getElementById('targetFees').innerText = data.fees || '0';
                            validateInstallments();
                        })
                        .catch(err => console.error('Error fetching course:', err));
                });

                // 5. Dynamic Installments & Total Calculation
                let installmentCount = 0;

                function skipSunday(date) {
                    const newDate = new Date(date);
                    if (newDate.getDay() === 0) { // 0 is Sunday
                        newDate.setDate(newDate.getDate() + 1);
                    }
                    return newDate.toISOString().split('T')[0];
                }

                document.getElementById('autoGenerateBtn').addEventListener('click', function () {
                    const totalFees = parseFloat(document.getElementById('totalFees').value) || 0;
                    const durationText = document.getElementById('courseDuration').value || '';
                    const durationMonths = parseInt(durationText) || 0;
                    let instAmount = parseFloat(document.getElementById('standardInstallment').value) || 0;

                    if (totalFees <= 0 || instAmount <= 0) {
                        alert('Please select a course and enter a valid installment amount.');
                        return;
                    }

                    if (durationMonths > 0) {
                        const minAmount = Math.ceil(totalFees / durationMonths);
                        if (instAmount < minAmount) {
                            alert(`For a ${durationMonths} month course, the minimum installment amount is ₹${minAmount} to avoid exceeding the duration. Adjusting automatically.`);
                            instAmount = minAmount;
                            document.getElementById('standardInstallment').value = instAmount;
                        }
                    }

                    const tbody = document.getElementById('installmentBody');
                    tbody.innerHTML = '';
                    let remaining = totalFees;
                    let count = 0;
                    let currentDate = new Date();

                    while (remaining > 0) {
                        count++;
                        const amount = Math.min(remaining, instAmount);
                        const row = document.createElement('tr');
                        
                        // Set date (Today, then +1 month)
                        if (count > 1) {
                            currentDate.setMonth(currentDate.getMonth() + 1);
                        }
                        const finalDateStr = skipSunday(currentDate);

                        row.innerHTML = `
                            <td class="installment-no">${count}</td>
                            <td><input type="number" class="form-control form-control-sm inst-amount" name="installments[amount][]" value="${amount}" required min="1"></td>
                            <td><input type="date" class="form-control form-control-sm disable-sunday" name="installments[date][]" value="${finalDateStr}" required></td>
                            <td>
                                <button type="button" class="btn btn-sm btn-outline-danger remove-installment">
                                    <i class="fas fa-times"></i>
                                </button>
                            </td>
                        `;
                        tbody.appendChild(row);
                        remaining -= amount;
                    }
                    
                    installmentCount = count;
                    calculateTotal();
                });

                document.getElementById('addInstallmentBtn').addEventListener('click', function () {
                    installmentCount++;
                    const tbody = document.getElementById('installmentBody');
                    const tr = document.createElement('tr');
                    
                    const lastDateInput = tbody.querySelector('tr:last-child input[type="date"]');
                    let nextDate = new Date();
                    if (lastDateInput && lastDateInput.value) {
                        nextDate = new Date(lastDateInput.value);
                        nextDate.setMonth(nextDate.getMonth() + 1);
                    }
                    const finalDateStr = skipSunday(nextDate);

                    tr.innerHTML = `
                        <td class="installment-no">${installmentCount}</td>
                        <td><input type="number" class="form-control form-control-sm inst-amount" name="installments[amount][]" required min="1"></td>
                        <td><input type="date" class="form-control form-control-sm disable-sunday" name="installments[date][]" value="${finalDateStr}" required></td>
                        <td>
                            <button type="button" class="btn btn-sm btn-outline-danger remove-installment">
                                <i class="fas fa-times"></i>
                            </button>
                        </td>
                    `;
                    tbody.appendChild(tr);
                    applySundayBlocker();
                    updateInstallmentNumbers();
                    calculateTotal();
                });

                document.getElementById('installmentBody').addEventListener('click', function (e) {
                    if (e.target.closest('.remove-installment')) {
                        e.target.closest('tr').remove();
                        updateInstallmentNumbers();
                        calculateTotal();
                    }
                });

                // Attach listener to table for dynamic inputs
                document.getElementById('installmentBody').addEventListener('input', function(e) {
                    if (e.target.classList.contains('inst-amount')) {
                        calculateTotal();
                    }
                });

                function updateInstallmentNumbers() {
                    const rows = document.querySelectorAll('#installmentBody tr');
                    installmentCount = rows.length;
                    rows.forEach((row, index) => {
                        row.querySelector('.installment-no').innerText = index + 1;
                    });
                }

                function calculateTotal() {
                    let total = 0;
                    document.querySelectorAll('.inst-amount').forEach(input => {
                        const val = parseFloat(input.value);
                        if (!isNaN(val)) total += val;
                    });
                    document.getElementById('installmentTotal').innerText = total;
                    validateInstallments();
                }

                function validateInstallments() {
                    const totalFees = parseFloat(document.getElementById('totalFees').value) || 0;
                    const currentTotal = parseFloat(document.getElementById('installmentTotal').innerText) || 0;
                    const warning = document.getElementById('installmentWarning');
                    const submitBtn = document.getElementById('submitBtn');

                    // Allow submission if no installments or if total matches
                    if (installmentCount > 0) {
                        if (Math.abs(currentTotal - totalFees) > 0.01) { // Floating point safety
                            warning.classList.remove('d-none');
                            submitBtn.disabled = true;
                        } else {
                            warning.classList.add('d-none');
                            submitBtn.disabled = false;
                        }
                    } else {
                        warning.classList.add('d-none');
                        submitBtn.disabled = false;
                    }
                }


                // 6. Tab Navigation (Next Buttons)
                document.querySelectorAll('.next-tab').forEach(button => {
                    button.addEventListener('click', function() {
                        const nextTabId = this.getAttribute('data-next');
                        const nextTabEl = document.querySelector(`[href="#${nextTabId}"]`);
                        if (nextTabEl) {
                            const tab = new bootstrap.Tab(nextTabEl);
                            tab.show();
                            window.scrollTo(0, 0);
                        }
                    });
                });

            </script>

            <%- include('../layout/footer') %>