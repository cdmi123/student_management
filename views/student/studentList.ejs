<%- include('../layout/header') %>

    <div class="d-sm-flex align-items-center justify-content-between mb-4 mt-3">
        <h1 class="h3 mb-0 text-gray-800">Student List</h1>
        <a href="/student/add" class="btn btn-sm btn-primary-theme shadow-sm"><i
                class="fas fa-plus fa-sm text-white-50 mr-2"></i> Register New Student</a>
    </div>

    <div class="card shadow mb-4">
        <div class="card-header py-3">
            <h6 class="m-0 font-weight-bold text-primary-theme">All Registered Students</h6>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-bordered table-hover" id="dataTable" width="100%" cellspacing="0">
                    <thead class="table-light">
                        <tr>
                            <th>Photo</th>
                            <th>Full Name</th>
                            <th>Contact</th>
                            <th>Course</th>
                            <th>Joining Date</th>
                            <th>Total Fees</th>
                            <th>Total Paid</th>
                            <th>Remaining Fees</th>
                            <th class="text-center">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if(students && students.length > 0) { %>
                            <% students.forEach(student => { 
                                // Calculate paid fees 
                                let totalPaid = 0; 
                                if(student.installments && student.installments.length > 0) {
                                    student.installments.forEach(inst => totalPaid += inst.amount);
                                }
                                let remaining = student.totalFees - totalPaid;
                            %>
                                    <tr>
                                        <td class="text-center">
                                            <% if(student.image) { %>
                                                <img src="/uploads/<%= student.image %>"
                                                    alt="<%= student.studentName %>" class="img-profile rounded-circle"
                                                    style="width:40px; height:40px; object-fit:cover;">
                                                <% } else { %>
                                                    <div class="icon-circle bg-secondary text-white mx-auto d-flex align-items-center justify-content-center"
                                                        style="width:40px; height:40px;">
                                                        <i class="fas fa-user"></i>
                                                    </div>
                                                    <% } %>
                                        </td>
                                        <td><span class="fw-bold">
                                                <%= student.studentName %>
                                                    <%= student.surname %>
                                            </span></td>
                                        <td>
                                            <%= student.studentContact %>
                                        </td>
                                        <td><span class="badge bg-info text-dark">
                                                <%= student.courseId ? student.courseId.courseName : 'N/A' %>
                                            </span></td>
                                        <td>
                                            <%= new Date(student.joiningDate).toLocaleDateString('en-IN') %>
                                        </td>
                                        <td>₹<%= student.totalFees.toLocaleString('en-IN') %>
                                        </td>
                                        <td class="text-success fw-bold">₹<%= totalPaid.toLocaleString('en-IN') %>
                                        </td>
                                        <td class="<%= remaining > 0 ? 'text-danger fw-bold' : 'text-success' %>">₹<%=
                                                remaining.toLocaleString('en-IN') %>
                                        </td>
                                        <td class="text-center">
                                            <div class="btn-group" role="group">
                                                <!-- View / Edit / Delete buttons. View only for now to keep it simple or implement later -->
                                                <button class="btn btn-sm btn-primary text-white me-1"
                                                    title="View Details">
                                                    <i class="fas fa-eye"></i>
                                                </button>
                                                <button class="btn btn-sm btn-info text-white me-1" title="Edit">
                                                    <i class="fas fa-edit"></i>
                                                </button>
                                                <button class="btn btn-sm btn-danger text-white" title="Delete">
                                                    <i class="fas fa-trash"></i>
                                                </button>
                                            </div>
                                        </td>
                                    </tr>
                                    <% }) %>
                                        <% } else { %>
                                            <tr>
                                                <td colspan="9" class="text-center py-4">No students found. <a
                                                        href="/student/add">Register a student.</a></td>
                                            </tr>
                                            <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <script>
        // Highlight sidebar active link
        document.querySelectorAll('#sidebar ul li a').forEach(el => {
            if (el.getAttribute('href') === '/student/list') {
                el.parentElement.classList.add('active');
            }
        });
    </script>

    <%- include('../layout/footer') %>